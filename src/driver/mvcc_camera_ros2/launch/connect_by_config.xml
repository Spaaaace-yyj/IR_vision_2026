<launch>
    <!-- 声明cam_sn参数，默认值为"None" -->
    <arg name="cam_sn" default="None" />
    <arg name="start_subscriber" default="false" />
    
    <node pkg="mvcc_camera_ros2" exec="hik_camera_image_pub" name="mvcc_camera_image_publisher" >
        <param from="$(find-pkg-share mvcc_camera_ros2)/config/hik_camera_config.yaml" />
        <!-- 支持通过命令行传入cam_sn参数 -->
        <param name="cam_sn" value="$(var cam_sn)" />
    </node>

    <node pkg="mvcc_camera_ros2" exec="hik_camera_image_sub" name="mvcc_camera_image_sub" if="$(var start_subscriber)">
    </node>
</launch>
